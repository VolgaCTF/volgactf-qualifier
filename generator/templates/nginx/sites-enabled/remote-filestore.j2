upstream remote_filestore {
  server seaweedfs:8888;
}

server {
  listen 80;
  server_name {{ volgactf.qualifier.remote_filestore.hostname }};

  location / {
    return 301 https://$host$request_uri;
  }
}

server {
  server_name {{ volgactf.qualifier.remote_filestore.hostname }};
  listen 443 ssl;

  http2 on;
  keepalive_timeout 300;
  charset utf-8;

  server_tokens off;

  ssl_certificate /etc/nginx/certs/{{ volgactf.qualifier.remote_filestore.hostname }}.pem;
  ssl_certificate_key /etc/nginx/certs/{{ volgactf.qualifier.remote_filestore.hostname }}-key.pem;

  access_log /dev/stdout combined;
  error_log /dev/stderr error;

  location / {
    proxy_set_header Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;

    proxy_pass http://remote_filestore/buckets/{{ volgactf.qualifier.remote_filestore.s3_bucket.name }}/;
    proxy_redirect off;

    proxy_http_version 1.1;

    add_header Strict-Transport-Security "max-age=15768000" always;
  }
}
